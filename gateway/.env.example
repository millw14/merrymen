# Merrymen AI gateway — copy to .env and fill in. These are SERVER-ONLY secrets;
# they never reach the merrymen client.

# The REAL upstream key (e.g. a Groq key from console.groq.com/keys). Server-only.
MERRYMEN_GATEWAY_UPSTREAM_KEY=

# HMAC secret that signs holder access tokens. Use 32+ random bytes, keep it stable
# (rotating it invalidates every issued token). Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MERRYMEN_GATEWAY_SECRET=

# Robinhood Chain (4663) RPC — used read-only for balanceOf to verify holdings.
MERRYMEN_GATEWAY_RPC=

# --- optional (sensible defaults) ---
# Upstream OpenAI-compatible chat endpoint (default: Groq).
# MERRYMEN_GATEWAY_UPSTREAM=https://api.groq.com/openai/v1/chat/completions
# The model the gateway forces server-side (the client never picks it).
# MERRYMEN_GATEWAY_MODEL=llama-3.3-70b-versatile
# Whole $MERRYMEN a wallet must hold to qualify (default 10000 = Villager tier).
# MERRYMEN_GATEWAY_MIN_TOKENS=10000
# Port (default 8787).
# PORT=8787
