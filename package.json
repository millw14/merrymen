{
  "name": "merrymen",
  "version": "0.16.0",
  "description": "Trading agents you never have to trust — self-hosted, keys stay on your machine, caps enforced by the account contract on-chain. For Robinhood Chain; Telegram control; write-your-own strategies.",
  "license": "MIT",
  "homepage": "https://merrymen.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/millw14/merrymen.git"
  },
  "bugs": {
    "url": "https://github.com/millw14/merrymen/issues"
  },
  "engines": {
    "node": ">=22.12"
  },
  "bin": {
    "merrymen": "cli/bin.mjs"
  },
  "files": [
    "cli",
    "web",
    "worker",
    "packages/core",
    "strategies",
    "tsconfig.json",
    "README.md",
    "!web/.next/cache",
    "!web/tsconfig.tsbuildinfo",
    "!web/public/merrymenlogo.png",
    "!**/*.test.ts"
  ],
  "scripts": {
    "onboard": "node cli/bin.mjs onboard",
    "start": "node cli/bin.mjs start",
    "doctor": "node cli/bin.mjs doctor",
    "status": "node cli/bin.mjs status",
    "build": "cd web && next build",
    "prepare": "node cli/build.mjs",
    "prepublishOnly": "node cli/prepublish.mjs",
    "dev:web": "cd web && next dev -p 3100 -H 127.0.0.1",
    "dev:worker": "tsx worker/src/index.ts",
    "test": "tsx --test \"worker/src/**/*.test.ts\"",
    "test:contracts": "cd contracts && npm test",
    "typecheck": "tsc --noEmit -p worker && tsc --noEmit -p web"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@zerodev/ecdsa-validator": "^5.4.9",
    "@zerodev/permissions": "^5.6.3",
    "@zerodev/sdk": "^5.5.10",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "viem": "^2.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
